@using ELITC_AI_Chatbot.Models
@inject IJSRuntime JS

<div class="fixed inset-0 z-50 flex items-center justify-center p-6">
    <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" @onclick="CloseEditor"></div>
    <div class="relative w-full max-w-2xl max-h-[90vh] bg-white rounded-3xl overflow-hidden shadow-2xl flex flex-col">
        <div class="p-6 border-b border-zinc-100 flex items-center justify-between bg-zinc-50/50">
            <h2 class="text-xl font-bold text-zinc-900">@(string.IsNullOrEmpty(Course.Id) ? "Add New Course" : "Edit Course")</h2>
            <button @onclick="CloseEditor" class="p-2 text-zinc-400 hover:text-zinc-600 hover:bg-zinc-100 rounded-lg transition-colors">
                <i data-lucide="x" class="w-5 h-5"></i>
            </button>
        </div>

        <div class="p-6 overflow-y-auto custom-scrollbar flex-1">
            <div class="grid grid-cols-2 gap-6">
                <div class="col-span-2 space-y-1">
                    <label class="text-sm font-semibold text-zinc-700">Course Title</label>
                    <input type="text" @bind="Course.Title" class="w-full px-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-elitc-gold/20 outline-none text-sm font-medium" />
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-semibold text-zinc-700">Category</label>
                    <input type="text" @bind="Course.Category" class="w-full px-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-elitc-gold/20 outline-none text-sm" />
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-semibold text-zinc-700">Level</label>
                    <input type="text" @bind="Course.Level" class="w-full px-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-elitc-gold/20 outline-none text-sm" />
                </div>
                <div class="col-span-2 space-y-1">
                    <label class="text-sm font-semibold text-zinc-700">Description</label>
                    <textarea @bind="Course.Description" rows="4" class="w-full px-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-elitc-gold/20 outline-none text-sm"></textarea>
                </div>
                <div class="col-span-2 space-y-1">
                    <label class="text-sm font-semibold text-zinc-700">Topics</label>
                    <textarea @bind="Course.Topics" rows="3" class="w-full px-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-elitc-gold/20 outline-none text-sm"></textarea>
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-semibold text-zinc-700">Prerequisites</label>
                    <input type="text" @bind="Course.Prerequisites" class="w-full px-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-elitc-gold/20 outline-none text-sm" />
                </div>
                <div class="space-y-1">
                    <label class="text-sm font-semibold text-zinc-700">Certification</label>
                    <input type="text" @bind="Course.Certification" class="w-full px-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-elitc-gold/20 outline-none text-sm" />
                </div>
                <div class="col-span-2 space-y-1">
                    <label class="text-sm font-semibold text-zinc-700">Roles</label>
                    <input type="text" @bind="Course.Roles" class="w-full px-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-elitc-gold/20 outline-none text-sm" />
                </div>
                <div class="col-span-2 space-y-1">
                    <label class="text-sm font-semibold text-zinc-700">Skills</label>
                    <input type="text" @bind="Course.Skills" class="w-full px-4 py-2.5 bg-zinc-50 border border-zinc-200 rounded-xl focus:ring-2 focus:ring-elitc-gold/20 outline-none text-sm" />
                </div>
            </div>
        </div>

        <div class="p-6 bg-zinc-50 border-t border-zinc-100 flex items-center justify-end gap-3">
            <button @onclick="CloseEditor" class="px-6 py-2.5 text-sm font-semibold text-zinc-500 hover:text-zinc-900 hover:bg-zinc-200/50 rounded-xl transition-all">Cancel</button>
            <button @onclick="SaveEditor" class="bg-zinc-900 hover:bg-zinc-800 text-white px-6 py-2.5 rounded-xl text-sm font-bold shadow-lg shadow-zinc-900/20 transition-all flex items-center gap-2">
                <i data-lucide="save" class="w-4 h-4"></i> Save Course
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter] public Course Course { get; set; } = new();
    [Parameter] public EventCallback OnClose { get; set; }
    [Parameter] public EventCallback<Course> OnSave { get; set; }

    private async Task CloseEditor()
    {
        await OnClose.InvokeAsync();
    }

    private async Task SaveEditor()
    {
        await OnSave.InvokeAsync(Course);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("chatInterop.initIcons");
    }
}
