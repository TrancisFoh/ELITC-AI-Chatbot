@using ELITC_AI_Chatbot.Models

@if (Courses != null && Courses.Any())
{
    <div class="relative group/carousel mt-3">
        @if (Courses.Count > 1)
        {
            <button onclick="this.parentElement.querySelector('.course-carousel-scroll').scrollBy({left: -250, behavior: 'smooth'})" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-3 w-8 h-8 bg-white border border-zinc-200 rounded-full shadow-md flex items-center justify-center text-zinc-600 hover:text-elitc-blue hover:border-elitc-blue transition-all z-10 opacity-0 group-hover/carousel:opacity-100 disabled:opacity-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m15 18-6-6 6-6"/></svg>
            </button>
        }
        
        <div class="course-carousel-scroll flex overflow-x-auto gap-3 pb-2 custom-scrollbar snap-x w-[calc(100%+16px)] -ml-2 px-2">
            @foreach (var course in Courses)
            {
                <div class="flex-shrink-0 w-[240px] bg-white rounded-xl shadow-sm border border-zinc-100 overflow-hidden flex flex-col snap-start hover:shadow-md transition-shadow group">
                    <div class="h-24 bg-gradient-to-br from-elitc-blue/10 to-elitc-gold/10 relative">
                        <div class="absolute inset-0 flex items-center justify-center p-4">
                            <h4 class="font-bold text-center text-elitc-blue line-clamp-2 text-sm">@course.Title</h4>
                        </div>
                    </div>
                    <div class="p-3 flex flex-col flex-1">
                        <div class="flex items-center justify-between mb-2">
                            <span class="text-[10px] font-semibold text-elitc-gold bg-elitc-gold/10 px-2 py-0.5 rounded-full uppercase tracking-wider">@course.Category</span>
                            <span class="text-xs text-zinc-500 font-medium">@course.Level</span>
                        </div>
                        <p class="text-xs text-zinc-600 line-clamp-2 mb-3 flex-1">@course.Synopsis</p>
                        <a href="@course.Url" target="_blank" rel="noopener noreferrer" class="mt-auto block w-full text-center text-xs font-semibold text-elitc-blue bg-elitc-blue/5 hover:bg-elitc-blue hover:text-white py-1.5 rounded-lg transition-colors">
                            View Course
                        </a>
                    </div>
                </div>
            }
        </div>

        @if (Courses.Count > 1)
        {
            <button onclick="this.parentElement.querySelector('.course-carousel-scroll').scrollBy({left: 250, behavior: 'smooth'})" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-3 w-8 h-8 bg-white border border-zinc-200 rounded-full shadow-md flex items-center justify-center text-zinc-600 hover:text-elitc-blue hover:border-elitc-blue transition-all z-10 opacity-0 group-hover/carousel:opacity-100 disabled:opacity-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m9 18 6-6-6-6"/></svg>
            </button>
        }
    </div>
}

@code {
    [Parameter]
    public List<Course>? Courses { get; set; }
}
