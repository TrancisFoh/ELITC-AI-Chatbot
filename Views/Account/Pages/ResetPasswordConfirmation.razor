@page "/Account/ResetPasswordConfirmation"
<PageTitle>Reset password confirmation</PageTitle>

<div class="min-h-screen bg-zinc-50 flex items-center justify-center p-6 font-sans">
    <div class="w-full max-w-md bg-white p-8 rounded-3xl border border-zinc-200 shadow-xl transition-all duration-500 transform translate-y-0 opacity-100">
        <div class="flex flex-col items-center mb-8">
            <div class="w-16 h-16 bg-emerald-500 rounded-2xl flex items-center justify-center mb-4 shadow-inner">
                <i data-lucide="check-circle" class="w-8 h-8 text-white"></i>
            </div>
            <h1 class="text-2xl font-bold text-zinc-900 text-center">Password Reset</h1>
            <p class="text-zinc-500 text-sm text-center mt-2">Your password has been successfully reset.</p>
        </div>

        <a href="Account/Login" class="w-full block text-center bg-zinc-900 text-white font-bold py-4 rounded-xl hover:bg-zinc-800 transition-all active:scale-95 cursor-pointer shadow-lg shadow-zinc-900/20">
            Log In Now
        </a>
    </div>
</div>
