@inherits LayoutComponentBase
@layout ELITC_AI_Chatbot.Views.Layout.MainLayout

<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-10 font-sans">
    <div class="flex items-center gap-4 mb-8">
        <div class="w-12 h-12 bg-zinc-900 rounded-2xl flex items-center justify-center border border-zinc-800 shadow-inner">
            <i data-lucide="user" class="w-6 h-6 text-elitc-gold"></i>
        </div>
        <div>
            <h1 class="text-3xl font-bold text-zinc-900 tracking-tight">Account Settings</h1>
            <p class="text-zinc-500 mt-1">Manage your account preferences, security, and personal data.</p>
        </div>
    </div>

    <div class="flex flex-col md:flex-row gap-8">
        <aside class="w-full md:w-64 shrink-0">
            <ManageNavMenu />
        </aside>
        <main class="flex-1 bg-white p-6 md:p-8 rounded-3xl border border-zinc-200 shadow-lg shadow-zinc-200/50">
            @Body
        </main>
    </div>
</div>
