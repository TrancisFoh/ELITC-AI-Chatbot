@using ELITC_AI_Chatbot.Models
@using ELITC_AI_Chatbot.Controllers
@inject DbService DbService
@inject IJSRuntime JS

<div class="flex flex-col lg:flex-row gap-6 h-[calc(100vh-210px)] min-h-[500px]">
    <div class="w-full lg:w-96 flex flex-col bg-white border border-zinc-200 rounded-3xl overflow-hidden shadow-sm">
        <div class="p-5 border-b border-zinc-100 flex flex-col gap-4 bg-zinc-50/50">
            <div class="flex items-center justify-between">
                <h3 class="font-bold text-zinc-900 flex items-center gap-2">
                    <i data-lucide="message-square" class="w-5 h-5 text-elitc-gold"></i>
                    Chat Sessions
                </h3>
                <button @onclick="LoadSessions" disabled="@isLoadingList" class="p-1.5 hover:bg-zinc-100 rounded-lg text-zinc-500 transition-colors disabled:opacity-50">
                    <i data-lucide="refresh-cw" class="w-4 h-4 @(isLoadingList ? "animate-spin" : "")"></i>
                </button>
            </div>
            
            <div class="relative">
                <i data-lucide="search" class="w-4 h-4 text-zinc-400 absolute left-3.5 top-3.5"></i>
                <input type="text" @bind="searchTerm" @bind:event="oninput" placeholder="Search session ID or message..." class="w-full pl-10 pr-4 py-2.5 bg-white border border-zinc-200 rounded-xl focus:ring-2 focus:ring-elitc-gold/20 outline-none text-sm transition-all" />
            </div>
        </div>

        <div class="flex-1 overflow-y-auto divide-y divide-zinc-100 custom-scrollbar">
            @if (isLoadingList)
            {
                <div class="flex flex-col items-center justify-center p-8 gap-3 text-zinc-400">
                    <i data-lucide="refresh-cw" class="w-6 h-6 animate-spin text-elitc-gold"></i>
                    <p class="text-sm font-medium">Loading session history...</p>
                </div>
            }
            else if (!filteredSessions.Any())
            {
                <div class="flex flex-col items-center justify-center p-8 gap-2 text-zinc-400 text-center">
                    <i data-lucide="alert-circle" class="w-8 h-8 text-zinc-300"></i>
                    <p class="text-sm font-bold text-zinc-700">No sessions found</p>
                    <p class="text-xs text-zinc-400 max-w-[200px]">No active conversations matched your search.</p>
                </div>
            }
            else
            {
                @foreach (var session in filteredSessions)
                {
                    <button @onclick="() => SelectSession(session.SessionId)" class="w-full text-left p-5 flex flex-col gap-2 transition-all cursor-pointer @(selectedSessionId == session.SessionId ? "bg-elitc-gold/5 border-l-4 border-elitc-gold" : "hover:bg-zinc-50 border-l-4 border-transparent")">
                        <div class="flex justify-between items-start w-full">
                            <span class="text-xs font-bold text-zinc-400 truncate max-w-[170px]">@session.SessionId</span>
                            <span class="bg-zinc-100 text-zinc-600 text-[10px] font-bold px-2 py-0.5 rounded-full shrink-0">@session.Count msgs</span>
                        </div>
                        <p class="text-xs font-medium text-zinc-800 line-clamp-2 pr-2">@(string.IsNullOrEmpty(session.LastMessage) ? "Empty conversation" : session.LastMessage)</p>
                        <div class="flex items-center gap-1.5 mt-1 text-[10px] font-bold text-zinc-400 uppercase tracking-wider">
                            <i data-lucide="clock" class="w-3 h-3 text-zinc-300"></i>
                            @FormatTime(session.LastActive)
                        </div>
                    </button>
                }
            }
        </div>
        
        <div class="p-3 bg-zinc-50 border-t border-zinc-100 text-[10px] text-center text-zinc-400 font-bold uppercase tracking-wider">
            ⏳ Auto-retention: Pruned after 7 days
        </div>
    </div>

    <div class="flex-1 flex flex-col bg-white border border-zinc-200 rounded-3xl overflow-hidden shadow-sm relative h-full">
        @if (!string.IsNullOrEmpty(selectedSessionId))
        {
            <div class="p-5 border-b border-zinc-100 flex items-center justify-between bg-zinc-50/50">
                <div>
                    <h4 class="font-bold text-zinc-900 text-sm">Transcript for Session</h4>
                    <p class="text-[11px] text-zinc-500 font-medium font-mono select-all mt-0.5">@selectedSessionId</p>
                </div>
                <button @onclick="LoadMessages" class="p-1.5 hover:bg-zinc-100 rounded-lg text-zinc-500 transition-colors">
                    <i data-lucide="refresh-cw" class="w-4 h-4 @(isLoadingTranscript ? "animate-spin" : "")"></i>
                </button>
            </div>

            <div class="flex-1 p-6 overflow-y-auto space-y-6 bg-zinc-50/30 custom-scrollbar">
                @if (isLoadingTranscript)
                {
                    <div class="absolute inset-0 bg-white/75 backdrop-blur-sm flex flex-col items-center justify-center gap-3">
                        <i data-lucide="refresh-cw" class="w-8 h-8 animate-spin text-elitc-gold"></i>
                        <p class="text-sm font-semibold text-zinc-600">Loading conversation history...</p>
                    </div>
                }
                else
                {
                    @foreach (var msg in messages)
                    {
                        bool isUser = msg.Role == "user";
                        <div class="flex gap-3.5 @(isUser ? "flex-row-reverse" : "")">
                            <div class="w-8 h-8 rounded-full flex items-center justify-center shrink-0 shadow-sm @(isUser ? "bg-zinc-950 border border-zinc-800" : "bg-white border border-zinc-200")">
                                <i data-lucide="@(isUser ? "user" : "bot")" class="w-4 h-4 @(isUser ? "text-zinc-400" : "text-elitc-gold")"></i>
                            </div>
                            <div class="max-w-[75%] space-y-1">
                                <div class="px-4 py-3 rounded-[20px] text-[13.5px] leading-relaxed shadow-sm @(isUser ? "bg-zinc-950 text-zinc-100 rounded-tr-none border border-zinc-800" : "bg-white border border-zinc-200/80 text-zinc-800 rounded-tl-none font-medium")">
                                    <div class="whitespace-pre-wrap">@msg.Content</div>
                                </div>
                                <div class="text-[9px] font-bold text-zinc-400 flex items-center gap-1 @(isUser ? "justify-end" : "justify-start")">
                                    <i data-lucide="clock" class="w-2.5 h-2.5 text-zinc-300"></i>
                                    @FormatTime(msg.Timestamp)
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        }
        else
        {
            <div class="flex-1 flex flex-col items-center justify-center p-8 gap-4 text-zinc-400 text-center">
                <div class="w-16 h-16 rounded-full bg-zinc-50 border border-zinc-100 flex items-center justify-center mb-2">
                    <i data-lucide="message-square" class="w-8 h-8 text-zinc-300"></i>
                </div>
                <h4 class="text-lg font-bold text-zinc-700">No Transcript Selected</h4>
                <p class="text-sm text-zinc-400 max-w-sm">Select a chat session from the list on the left to review the conversation log.</p>
            </div>
        }
    </div>
</div>

@code {
    private List<ChatSessionSummary> sessions = new();
    private List<ChatLog> messages = new();
    private string? selectedSessionId;
    private string searchTerm = "";
    private bool isLoadingList = false;
    private bool isLoadingTranscript = false;

    private IEnumerable<ChatSessionSummary> filteredSessions => sessions.Where(s => 
        string.IsNullOrEmpty(searchTerm) || 
        s.SessionId.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
        s.LastMessage.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadSessions();
    }

    private async Task LoadSessions()
    {
        isLoadingList = true;
        var allLogs = await DbService.GetAllChatLogsAsync();
        
        sessions = allLogs
            .GroupBy(l => l.SessionId)
            .Select(g => new ChatSessionSummary
            {
                SessionId = g.Key,
                Count = g.Count(),
                LastActive = g.Max(l => l.Timestamp),
                LastMessage = g.OrderByDescending(l => l.Timestamp).FirstOrDefault()?.Content ?? ""
            })
            .OrderByDescending(s => s.LastActive)
            .ToList();
            
        isLoadingList = false;
        
        // Ensure UI updates so JS can render icons on the newly generated list
        StateHasChanged();
        await JS.InvokeVoidAsync("chatInterop.initIcons");
    }

    private async Task SelectSession(string sessionId)
    {
        selectedSessionId = sessionId;
        await LoadMessages();
    }

    private async Task LoadMessages()
    {
        if (string.IsNullOrEmpty(selectedSessionId)) return;
        
        isLoadingTranscript = true;
        messages = await DbService.GetChatSessionMessagesAsync(selectedSessionId);
        isLoadingTranscript = false;
        
        StateHasChanged();
        await JS.InvokeVoidAsync("chatInterop.initIcons");
    }

    private string FormatTime(long timestamp)
    {
        var dto = DateTimeOffset.FromUnixTimeMilliseconds(timestamp).ToLocalTime();
        return dto.ToString("MMM dd 'at' hh:mm tt");
    }

    public class ChatSessionSummary
    {
        public string SessionId { get; set; } = "";
        public int Count { get; set; }
        public long LastActive { get; set; }
        public string LastMessage { get; set; } = "";
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("chatInterop.initIcons");
        }
    }
}
