@using ELITC_AI_Chatbot.Models

@if (Courses != null && Courses.Any())
{
    <div class="relative group/carousel mt-3">
        @if (Courses.Count > 1)
        {
            <button onclick="this.parentElement.querySelector('.course-carousel-scroll').scrollBy({left: -250, behavior: 'smooth'})" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-3 w-8 h-8 bg-white border border-zinc-200 rounded-full shadow-md flex items-center justify-center text-zinc-600 hover:text-elitc-blue hover:border-elitc-blue transition-all z-10 opacity-0 group-hover/carousel:opacity-100 disabled:opacity-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m15 18-6-6 6-6"/></svg>
            </button>
        }
        
        <div class="course-carousel-scroll flex overflow-x-auto gap-3 pb-2 custom-scrollbar snap-x w-[calc(100%+16px)] -ml-2 px-2">
            @foreach (var course in Courses)
            {
                <div class="flex-shrink-0 w-[240px] md:w-[280px] bg-white rounded-xl shadow-md border border-zinc-100 overflow-hidden flex flex-col snap-start group hover:shadow-lg transition-shadow">
                    <div class="bg-[#fde047] h-[150px] p-5 flex items-center justify-center">
                        <h4 class="font-bold text-center text-zinc-900 text-[15px] leading-snug">@course.Title</h4>
                    </div>
                    
                    <div class="p-5 flex flex-col flex-1 bg-white">
                        <div class="flex items-center gap-2 mb-3 text-[13px] text-zinc-600">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 text-[#fde047] fill-[#fde047]/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z"/><path d="M7 7h.01"/></svg>
                            <span>Category: <span class="font-bold text-zinc-900">@course.Category</span></span>
                        </div>
                        
                        <div class="flex items-center gap-2 mb-4 text-[13px] text-zinc-600">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0 text-zinc-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                            <span>Duration: <span class="font-bold text-zinc-900">@course.Duration</span></span>
                        </div>
                        
                        <div class="border-t border-dashed border-zinc-200 my-2"></div>
                        
                        <a href="@course.Url" target="_blank" rel="noopener noreferrer" class="mt-2 block w-full text-center text-[13px] font-bold text-elitc-blue hover:text-blue-800 transition-colors">
                            View Course &rarr;
                        </a>
                    </div>
                </div>
            }
        </div>

        @if (Courses.Count > 1)
        {
            <button onclick="this.parentElement.querySelector('.course-carousel-scroll').scrollBy({left: 250, behavior: 'smooth'})" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-3 w-8 h-8 bg-white border border-zinc-200 rounded-full shadow-md flex items-center justify-center text-zinc-600 hover:text-elitc-blue hover:border-elitc-blue transition-all z-10 opacity-0 group-hover/carousel:opacity-100 disabled:opacity-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4"><path d="m9 18 6-6-6-6"/></svg>
            </button>
        }
    </div>
}

@code {
    [Parameter]
    public List<Course>? Courses { get; set; }
}
