@if (Show)
{
    <button @onclick="OnClick" class="absolute bottom-20 left-1/2 -translate-x-1/2 bg-white/90 backdrop-blur text-elitc-blue border border-elitc-blue/20 shadow-md rounded-full px-4 py-1.5 text-xs font-semibold flex items-center gap-2 hover:bg-zinc-50 hover:scale-105 transition-all z-10 animate-fade-in-up">
        Scroll to recent
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
    </button>
}

@code {
    [Parameter]
    public bool Show { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }
}
