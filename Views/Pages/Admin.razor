@page "/admin"
@using Microsoft.AspNetCore.Authorization
@using ELITC_AI_Chatbot.Views.Admin
@using ELITC_AI_Chatbot.Controllers
@using Microsoft.AspNetCore.Identity
@using ELITC_AI_Chatbot.Models.Data
@attribute [Authorize(Roles = "Admin,Moderator")]
@inject IJSRuntime JS
@inject UserManager<ApplicationUser> AppUserManager
@inject GeminiService GeminiService
@inject DbService DbService
@inject AuthenticationStateProvider AuthStateProvider
@inject GeminiService GeminiService
@rendermode InteractiveServer

<PageTitle>Admin Dashboard</PageTitle>

<div class="min-h-screen bg-zinc-50 font-sans flex">
    <!-- Sidebar -->
    <aside class="fixed left-0 top-0 h-full w-64 bg-zinc-950 text-zinc-400 p-4 flex flex-col hidden lg:flex border-r border-zinc-800">
        <div class="flex items-center gap-3 px-2 mb-8 mt-2">
            <div class="w-10 h-10 bg-elitc-gold/20 rounded-xl flex items-center justify-center border border-elitc-gold/30">
                <i data-lucide="shield-check" class="w-5 h-5 text-elitc-gold"></i>
            </div>
            <div>
                <h1 class="text-white font-bold text-sm tracking-wide uppercase">Hello, @(string.IsNullOrWhiteSpace(currentUser?.FullName) ? currentUser?.UserName : currentUser?.FullName)</h1>
                <p class="text-xs text-zinc-500 font-medium">System Administration</p>
            </div>
        </div>

        <nav class="flex-1 space-y-2">
            @if (isAdmin || allowedTabs.Contains("courses"))
            {
                <button @onclick="@(() => activeTab = "courses")" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm @(activeTab == "courses" ? "bg-white text-zinc-900 shadow-md" : "hover:bg-zinc-900 hover:text-white")">
                    <i data-lucide="book-open" class="w-4 h-4"></i>
                    Courses
                </button>
            }
            @if (isAdmin || allowedTabs.Contains("config"))
            {
                <button @onclick="@(() => activeTab = "config")" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm @(activeTab == "config" ? "bg-white text-zinc-900 shadow-md" : "hover:bg-zinc-900 hover:text-white")">
                    <i data-lucide="settings" class="w-4 h-4"></i>
                    Configuration
                </button>
            }
            @if (isAdmin || allowedTabs.Contains("appearance"))
            {
                <button @onclick="@(() => activeTab = "appearance")" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm @(activeTab == "appearance" ? "bg-white text-zinc-900 shadow-md" : "hover:bg-zinc-900 hover:text-white")">
                    <i data-lucide="image" class="w-4 h-4"></i>
                    Appearance
                </button>
            }
            @if (isAdmin || allowedTabs.Contains("system"))
            {
                <button @onclick="@(() => activeTab = "system")" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm @(activeTab == "system" ? "bg-white text-zinc-900 shadow-md" : "hover:bg-zinc-900 hover:text-white")">
                    <i data-lucide="server" class="w-4 h-4"></i>
                    System Tools
                </button>
            }
            @if (isAdmin || allowedTabs.Contains("chats"))
            {
                <button @onclick="@(() => activeTab = "chats")" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm @(activeTab == "chats" ? "bg-white text-zinc-900 shadow-md" : "hover:bg-zinc-900 hover:text-white")">
                    <i data-lucide="message-square" class="w-4 h-4"></i>
                    Chat Logs
                </button>
            }
            @if (isAdmin || allowedTabs.Contains("errors"))
            {
                <button @onclick="@(() => activeTab = "errors")" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm @(activeTab == "errors" ? "bg-white text-zinc-900 shadow-md" : "hover:bg-zinc-900 hover:text-white")">
                    <i data-lucide="alert-triangle" class="w-4 h-4"></i>
                    Error Logs
                </button>
            }
            @if (isAdmin || allowedTabs.Contains("users"))
            {
                <button @onclick="@(() => activeTab = "users")" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm @(activeTab == "users" ? "bg-white text-zinc-900 shadow-md" : "hover:bg-zinc-900 hover:text-white")">
                    <i data-lucide="users" class="w-4 h-4"></i>
                    User Management
                </button>
            }
            @if (isAdmin || allowedTabs.Contains("audit"))
            {
                <button @onclick="@(() => activeTab = "audit")" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl transition-all font-medium text-sm @(activeTab == "audit" ? "bg-white text-zinc-900 shadow-md" : "hover:bg-zinc-900 hover:text-white")">
                    <i data-lucide="clipboard-list" class="w-4 h-4"></i>
                    Audit Logs
                </button>
            }
        </nav>

        <div class="mt-auto pt-6 border-t border-zinc-900">
            <div class="px-4 py-3 bg-zinc-900/50 rounded-xl border border-zinc-800/50 flex flex-col gap-1 mb-4">
                <div class="text-xs font-semibold text-zinc-500 uppercase tracking-wider">Chatbot Status</div>
                <div class="text-sm text-white flex items-center gap-2">
                    @if (isCheckingHealth)
                    {
                        <span class="w-2 h-2 rounded-full bg-yellow-400 animate-pulse"></span>
                        <span class="text-yellow-400">Checking...</span>
                    }
                    else if (isChatbotHealthy)
                    {
                        <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                        <span class="text-emerald-400">@chatbotStatusMessage</span>
                    }
                    else
                    {
                        <span class="w-2 h-2 rounded-full bg-rose-500"></span>
                        <span class="text-rose-400">@chatbotStatusMessage</span>
                    }
                </div>
            </div>
            
            <a href="/Account/Manage" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-zinc-400 hover:bg-zinc-900 hover:text-white transition-all font-medium text-sm text-left mb-2">
                <i data-lucide="user" class="w-4 h-4"></i>
                Account Settings
            </a>
            
            <form action="/Account/Logout" method="post">
                <AntiforgeryToken />
                <input type="hidden" name="ReturnUrl" value="" />
                <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-rose-500 hover:bg-rose-500/10 hover:text-rose-400 transition-all font-medium text-sm text-left">
                    <i data-lucide="log-out" class="w-4 h-4"></i>
                    Sign Out
                </button>
            </form>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 lg:ml-64 p-6 lg:p-10 min-h-screen bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-zinc-100/50 via-white to-white">
        <header class="mb-10">
            <h1 class="text-3xl font-bold text-zinc-900 tracking-tight">
                @(activeTab == "courses" ? "Course Catalog" : 
                  activeTab == "config" ? "Bot Configuration" : 
                  activeTab == "appearance" ? "Bot Appearance" : 
                  activeTab == "system" ? "System Control" : 
                  activeTab == "chats" ? "Chat Audit Logs" : 
                  activeTab == "errors" ? "System Error Logs" : 
                  activeTab == "audit" ? "Audit Logs" : 
                  "User Management")
            </h1>
            <p class="text-zinc-500 text-base mt-1">Manage the core intelligence and data assets of your ELITC Assistant.</p>
        </header>

        @if (!isInitializing)
        {
            if ((isAdmin || allowedTabs.Contains("courses")) && activeTab == "courses")
            {
                <CourseManager />
            }
            else if ((isAdmin || allowedTabs.Contains("config")) && activeTab == "config")
            {
                <ConfigManager />
            }
            else if ((isAdmin || allowedTabs.Contains("appearance")) && activeTab == "appearance")
            {
                <AppearanceManager />
            }
            else if ((isAdmin || allowedTabs.Contains("system")) && activeTab == "system")
            {
                <SystemTools />
            }
            else if ((isAdmin || allowedTabs.Contains("chats")) && activeTab == "chats")
            {
                <ChatLogManager />
            }
            else if ((isAdmin || allowedTabs.Contains("errors")) && activeTab == "errors")
            {
                <ErrorLogManager />
            }
            else if ((isAdmin || allowedTabs.Contains("users")) && activeTab == "users")
            {
                <UserManager />
            }
            else if ((isAdmin || allowedTabs.Contains("audit")) && activeTab == "audit")
            {
                <AuditLogs />
            }
        }
        else
        {
            <div class="flex items-center justify-center p-12">
                <i data-lucide="loader-2" class="w-8 h-8 animate-spin text-zinc-400"></i>
            </div>
        }
    </main>
</div>

@code {
    private string activeTab = "courses";
    private bool isChatbotHealthy = false;
    private bool isCheckingHealth = true;
    private string chatbotStatusMessage = "Checking...";

    private bool isAdmin = false;
    private bool isInitializing = true;
    private List<string> allowedTabs = new();
    private ApplicationUser? currentUser;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        isAdmin = user.IsInRole("Admin");
        
        currentUser = await AppUserManager.GetUserAsync(user);
        
        if (!isAdmin && user.IsInRole("Moderator"))
        {
            if (currentUser != null)
            {
                var claims = await AppUserManager.GetClaimsAsync(currentUser);
                var tabsClaim = claims.FirstOrDefault(c => c.Type == "AllowedTabs");
                if (tabsClaim != null && !string.IsNullOrWhiteSpace(tabsClaim.Value))
                {
                    allowedTabs = tabsClaim.Value.Split(',', StringSplitOptions.RemoveEmptyEntries).ToList();
                }
            }
            
            if (!allowedTabs.Contains(activeTab) && allowedTabs.Any())
            {
                activeTab = allowedTabs.First();
            }
        }

        await CheckChatbotHealth();
        isInitializing = false;
    }

    private async Task CheckChatbotHealth()
    {
        isCheckingHealth = true;
        try
        {
            var (isHealthy, message) = await GeminiService.CheckHealthAsync();
            isChatbotHealthy = isHealthy;
            chatbotStatusMessage = message;
        }
        catch
        {
            isChatbotHealthy = false;
            chatbotStatusMessage = "Health Check Failed";
        }
        isCheckingHealth = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("chatInterop.initIcons");
    }
}
