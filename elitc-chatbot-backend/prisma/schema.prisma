generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 1. The User Table
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  
  // A user can have many chats
  chats     Chat[]   
}

// 2. The Chat Session Table
model Chat {
  id        String    @id @default(uuid())
  title     String
  createdAt DateTime  @default(now())
  
  // Link to the User who owns this chat
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  
  // A chat has many messages
  messages  Message[] 
}

// 3. The Messages Table
model Message {
  id        String   @id @default(uuid())
  role      String   // e.g., 'user' or 'assistant'
  content   String   // <-- Removed @db.Text here!
  createdAt DateTime @default(now())
  
  // Link to the Chat this message belongs to
  chatId    String
  chat      Chat     @relation(fields: [chatId], references: [id])
}