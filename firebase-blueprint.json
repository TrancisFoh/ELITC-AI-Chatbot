{
  "entities": {
    "Course": {
      "title": "Course",
      "description": "An ELITC course catalog item.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "prerequisites": { "type": "array" },
        "price": { "type": "number" },
        "duration": { "type": "string" },
        "level": { "type": "string" },
        "url": { "type": "string" },
        "category": { "type": "string" }
      },
      "required": ["id", "title", "description", "category"]
    },
    "Config": {
      "title": "Config",
      "description": "Application configuration and prompts.",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["key", "value"]
    }
  },
  "firestore": {
    "/courses/{courseId}": {
      "schema": "Course",
      "description": "Collection of all ELITC courses."
    },
    "/configs/{configId}": {
      "schema": "Config",
      "description": "System configuration and instruction sets."
    },
    "/admins/{userId}": {
      "schema": "object",
      "description": "Admin users list."
    }
  }
}
