rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // --- Course Validation ---
    function isValidCourse(data) {
      return data.keys().hasAll(['id', 'title', 'description', 'category']) &&
             data.keys().size() <= 10 &&
             data.id is string && data.id.size() <= 50 &&
             data.title is string && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.category is string && data.category.size() <= 100 &&
             (data.get('price', 0) is number) &&
             (data.get('duration', '') is string && data.get('duration', '').size() <= 100) &&
             (data.get('level', '') is string && data.get('level', '').size() <= 100) &&
             (data.get('url', '') is string && data.get('url', '').size() <= 500);
    }

    // --- Config Validation ---
    function isValidConfig(data) {
      return data.keys().hasAll(['key', 'value']) &&
             data.keys().size() == 2 &&
             data.key is string && data.key.size() <= 100 &&
             data.value is string && data.value.size() <= 10000;
    }

    // --- Rules ---

    match /courses/{courseId} {
      allow read: if true;
      // Protected by schema validation. In a real app, this would be isAdmin()
      allow write: if isValidCourse(incoming());
    }

    match /configs/{configId} {
      allow read: if true;
      allow write: if isValidConfig(incoming());
    }

    match /admins/{userId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
