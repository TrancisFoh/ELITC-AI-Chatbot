@page "/Account/InvalidUser"

<PageTitle>Invalid User</PageTitle>

<div class="min-h-screen bg-zinc-50 flex items-center justify-center p-6 font-sans">
    <div class="w-full max-w-md bg-white p-8 rounded-3xl border border-zinc-200 shadow-xl transition-all duration-500 transform translate-y-0 opacity-100">
        <div class="flex flex-col items-center mb-6">
            <div class="w-16 h-16 bg-rose-50 rounded-2xl flex items-center justify-center mb-4 border border-rose-100 shadow-inner">
                <i data-lucide="user-x" class="w-8 h-8 text-rose-500"></i>
            </div>
            <h1 class="text-2xl font-bold text-zinc-900">Session Invalid</h1>
            <p class="text-zinc-500 text-sm text-center mt-2">We couldn't load your user profile. Your session may have expired or the account no longer exists.</p>
        </div>

        <div class="mb-8">
            <StatusMessage />
        </div>

        <a href="Account/Login" class="w-full block text-center bg-zinc-900 text-white font-bold py-4 rounded-xl hover:bg-zinc-800 transition-all active:scale-95 cursor-pointer shadow-lg shadow-zinc-900/20">
            Return to Login
        </a>
    </div>
</div>

@code {
    [Inject] private IJSRuntime JS { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("chatInterop.initIcons");
        }
    }
}
