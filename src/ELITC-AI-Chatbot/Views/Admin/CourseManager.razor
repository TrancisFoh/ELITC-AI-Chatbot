@using ELITC_AI_Chatbot.Models
@using ELITC_AI_Chatbot.Controllers
@using System.Text.Json
@inject DbService DbService
@inject IJSRuntime JS
@inject IWebHostEnvironment Env

<div class="bg-white rounded-2xl border border-zinc-200 shadow-sm p-6 overflow-hidden">
    <div class="flex justify-between items-center mb-6">
        <div class="relative w-72">
            <i data-lucide="search" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-zinc-400"></i>
            <input type="text" @bind="searchTerm" @bind:event="oninput" placeholder="Search courses..." class="w-full pl-9 pr-4 py-2 bg-zinc-50 border border-zinc-200 rounded-lg text-sm focus:ring-2 focus:ring-elitc-gold/20 outline-none" />
        </div>
        <div class="flex gap-2">
            <button @onclick="ImportCoursesFromJson" disabled="@isImporting" class="bg-zinc-100 hover:bg-zinc-200 disabled:opacity-50 text-zinc-900 px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2">
                <i data-lucide="download" class="w-4 h-4"></i> @(isImporting ? "Importing..." : "Import Courses")
            </button>
            <button @onclick="() => isEditing = true" class="bg-zinc-900 hover:bg-zinc-800 text-white px-4 py-2 rounded-lg text-sm font-semibold flex items-center gap-2">
                <i data-lucide="plus" class="w-4 h-4"></i> Add Course
            </button>
        </div>
    </div>
    
    <table class="w-full text-left text-sm text-zinc-600">
        <thead class="bg-zinc-50 text-xs uppercase font-semibold text-zinc-500 border-b border-zinc-100">
            <tr>
                <th class="px-4 py-3 rounded-tl-xl">Course Title</th>
                <th class="px-4 py-3">Category</th>
                <th class="px-4 py-3">Course Code</th>
                <th class="px-4 py-3 text-right rounded-tr-xl">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-zinc-100">
            @if (courses == null)
            {
                <tr><td colspan="4" class="px-4 py-4 text-center">Loading...</td></tr>
            }
            else if (!filteredCourses.Any())
            {
                <tr><td colspan="4" class="px-4 py-8 text-center text-zinc-400">No courses found. Add a course to get started!</td></tr>
            }
            else
            {
                @foreach (var course in filteredCourses)
                {
                    <tr class="hover:bg-zinc-50/50 transition-colors">
                        <td class="px-4 py-4 font-medium text-zinc-900">@course.Title</td>
                        <td class="px-4 py-4"><span class="px-2.5 py-1 rounded-full text-xs font-semibold @GetCategoryColor(course.Category)">@course.Category</span></td>
                        <td class="px-4 py-4 font-mono text-xs font-semibold text-zinc-600">@course.Id</td>
                        <td class="px-4 py-4 text-right">
                            <div class="flex items-center justify-end gap-2">
                                <button @onclick="() => EditCourse(course)" class="p-2 text-zinc-400 hover:text-blue-500 bg-white hover:bg-blue-50 border border-zinc-200 hover:border-blue-200 rounded-lg transition-all"><i data-lucide="edit-2" class="w-4 h-4"></i></button>
                                <button @onclick="() => ConfirmDelete(course.Id)" class="p-2 text-zinc-400 hover:text-rose-500 bg-white hover:bg-rose-50 border border-zinc-200 hover:border-rose-200 rounded-lg transition-all"><i data-lucide="trash-2" class="w-4 h-4"></i></button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@if (isEditing)
{
    <CourseEditor Course="editingCourse" IsNewCourse="@(string.IsNullOrEmpty(editingCourse.Id))" OnClose="CloseEditor" OnSave="SaveCourse" />
}

@if (courseToDelete != null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-6">
        <div class="absolute inset-0 bg-black/40 backdrop-blur-sm" @onclick="() => courseToDelete = null"></div>
        <div class="relative w-full max-w-md bg-white rounded-3xl overflow-hidden shadow-2xl flex flex-col transform scale-100 opacity-100">
            <div class="p-8 pb-6 flex flex-col items-center text-center">
                <div class="w-16 h-16 bg-rose-50 text-rose-500 rounded-full flex items-center justify-center mb-4">
                    <i data-lucide="alert-circle" class="w-8 h-8"></i>
                </div>
                <h2 class="text-xl font-bold text-zinc-900 mb-2">Delete Course?</h2>
                <p class="text-sm text-zinc-500">Are you sure you want to delete this course? This action cannot be undone.</p>
            </div>
            <div class="p-6 bg-zinc-50 border-t border-zinc-100 flex items-center justify-end gap-3">
                <button @onclick="() => courseToDelete = null" class="px-6 py-2.5 text-sm font-semibold text-zinc-500 hover:text-zinc-900 transition-colors">Cancel</button>
                <button @onclick="DeleteCourse" class="bg-rose-500 hover:bg-rose-600 text-white px-6 py-2.5 rounded-xl text-sm font-bold shadow-lg shadow-rose-500/20 transition-all">Yes, Delete It</button>
            </div>
        </div>
    </div>
}

@code {
    private List<Course> courses = new();
    private string searchTerm = "";
    private bool isImporting = false;
    private bool isEditing = false;
    private Course editingCourse = new Course();
    private string? courseToDelete;

    private IEnumerable<Course> filteredCourses => courses.Where(c => 
        string.IsNullOrEmpty(searchTerm) || 
        c.Title.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) || 
        c.Category.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadCourses();
    }

    private async Task LoadCourses()
    {
        courses = await DbService.GetAllCoursesAsync();
    }

    private void EditCourse(Course course)
    {
        editingCourse = new Course 
        { 
            Id = course.Id, Title = course.Title, Synopsis = course.Synopsis, Category = course.Category, 
            Level = course.Level, Duration = course.Duration, TargetAudience = course.TargetAudience, 
            Url = course.Url 
        };
        isEditing = true;
    }

    private void CloseEditor()
    {
        isEditing = false;
        editingCourse = new Course();
    }

    private async Task SaveCourse(Course course)
    {
        if (string.IsNullOrEmpty(course.Id)) course.Id = Guid.NewGuid().ToString();
        await DbService.SaveCourseAsync(course);
        await LoadCourses();
        CloseEditor();
    }

    private void ConfirmDelete(string id)
    {
        courseToDelete = id;
    }

    private async Task DeleteCourse()
    {
        if (courseToDelete != null)
        {
            await DbService.DeleteCourseAsync(courseToDelete);
            await LoadCourses();
            courseToDelete = null;
        }
    }

    private async Task ImportCoursesFromJson()
    {
        isImporting = true;
        try 
        {
            var jsonPath = System.IO.Path.Combine(Env.ContentRootPath, "courses.json");
            if (System.IO.File.Exists(jsonPath))
            {
                var json = await System.IO.File.ReadAllTextAsync(jsonPath);
                var options = new JsonSerializerOptions { PropertyNameCaseInsensitive = true };
                var importedCourses = JsonSerializer.Deserialize<List<CourseImportDto>>(json, options);
                
                if (importedCourses != null)
                {
                    foreach(var dto in importedCourses)
                    {
                        var course = new Course
                        {
                            Id = string.IsNullOrEmpty(dto.Id) ? Guid.NewGuid().ToString() : dto.Id,
                            Title = dto.Title ?? "Untitled Course",
                            Category = dto.Category ?? "Uncategorized",
                            Level = dto.Level ?? "Beginner",
                            Synopsis = dto.Synopsis ?? "No synopsis available.",
                            Duration = dto.Duration ?? "",
                            TargetAudience = dto.TargetAudience != null ? string.Join(", ", dto.TargetAudience) : "",
                            Url = dto.Url ?? ""
                        };

                        await DbService.SaveCourseAsync(course);
                    }
                    await LoadCourses();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Import error: {ex.Message}");
        }
        finally
        {
            isImporting = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await JS.InvokeVoidAsync("chatInterop.initIcons");
    }

    private class CourseImportDto
    {
        public string? Id { get; set; }
        public string? Title { get; set; }
        public string? Synopsis { get; set; }
        public string? Category { get; set; }
        public string? Level { get; set; }
        public string? Duration { get; set; }
        public string? Url { get; set; }
        public List<string>? TargetAudience { get; set; }
    }

    private string GetCategoryColor(string? category)
    {
        return category?.ToLower() switch
        {
            "wsq" => "bg-violet-50 text-violet-700 border border-violet-200",
            "skills improvement" => "bg-emerald-50 text-emerald-700 border border-emerald-200",
            "certification" => "bg-purple-50 text-purple-700 border border-purple-200",
            "ai & digital" => "bg-sky-50 text-sky-700 border border-sky-200",
            "ipc" => "bg-orange-50 text-orange-700 border border-orange-200",
            "foreign workers" => "bg-cyan-50 text-cyan-700 border border-cyan-200",
            _ => "bg-zinc-50 text-zinc-700 border border-zinc-200"
        };
    }

    private string GetLevelColor(string? level)
    {
        return level?.ToLower() switch
        {
            "beginner" => "bg-teal-50 text-teal-700 border border-teal-200",
            "intermediate" => "bg-amber-50 text-amber-700 border border-amber-200",
            "professional" or "advanced" => "bg-rose-50 text-rose-700 border border-rose-200",
            _ => "bg-zinc-50 text-zinc-600 border border-zinc-200"
        };
    }
}
